# Backend Environment Variables
# Copy to .env and fill in values

# Database connection string
DATABASE_URL=postgresql://user:password@localhost:5432/secureshield_db

# JWT Secret Key (generate a long random string)
SECRET_KEY=change_this_to_a_long_random_secret_key

# JWT Algorithm (default: HS256)
ALGORITHM=HS256

# Access token expiry in minutes (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Fernet encryption key for API key storage
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Frontend URL for CORS (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:5173

# CORS Origins (comma-separated, overrides FRONTEND_URL)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
